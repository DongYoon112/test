<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/summaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingBottom="12dp"
            android:text="Awaiting first frame." />

        <TextView
            android:id="@+id/bleedingText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/breathingText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/consciousText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/personText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/listsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/speechLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Recent speech:"
            android:textStyle="bold"
            android:paddingTop="12dp" />

        <TextView
            android:id="@+id/speechText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:paddingBottom="12dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#444"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Triage decision"
            android:textStyle="bold"
            android:textSize="14sp"
            android:paddingBottom="6dp" />

        <TextView
            android:id="@+id/decisionPrimaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/decisionSecondaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/decisionFocusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/decisionBlockersText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/decisionMissingText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/decisionRationaleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:fontStyle="italic"
            android:alpha="0.85"
            android:paddingBottom="12dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#444"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clarification"
            android:textStyle="bold"
            android:textSize="14sp"
            android:paddingBottom="6dp" />

        <TextView
            android:id="@+id/clarNeedText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/clarCandidatesText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/clarPromptText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/clarGainText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/clarRationaleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:fontStyle="italic"
            android:alpha="0.85"
            android:paddingBottom="12dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#444"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Action plan"
            android:textStyle="bold"
            android:textSize="14sp"
            android:paddingBottom="6dp" />

        <TextView
            android:id="@+id/planStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/planSecondaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/planBlockersText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/planSafetyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/planStepsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/planRationaleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:fontStyle="italic"
            android:alpha="0.85"
            android:paddingBottom="12dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#444"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Voice"
            android:textStyle="bold"
            android:textSize="14sp"
            android:paddingBottom="6dp" />

        <TextView
            android:id="@+id/voiceLastSpokenText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:paddingBottom="12dp"
            android:text="(nothing spoken yet)" />

        <TextView
            android:id="@+id/guidanceStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/guidanceDetailText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/guidanceRationaleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:fontStyle="italic"
            android:alpha="0.85"
            android:paddingBottom="12dp" />

        <TextView
            android:id="@+id/adaptModeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/adaptMetricsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:paddingBottom="12dp" />

        <TextView
            android:id="@+id/footerText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:alpha="0.7" />
    </LinearLayout>
</ScrollView>
