<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/aegis_bg"
    android:paddingStart="18dp"
    android:paddingEnd="18dp"
    android:paddingTop="24dp"
    android:paddingBottom="18dp"
    android:fitsSystemWindows="true">

    <!-- Header: logo + wordmark + header chips -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_aegis_logo"
            android:contentDescription="@string/app_name" />

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@color/aegis_text"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.03" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/app_tagline"
                android:textColor="@color/aegis_text_dim"
                android:textSize="12sp" />
        </LinearLayout>

        <Button
            android:id="@+id/reportButton"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:minWidth="0dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_header_chip"
            android:stateListAnimator="@null"
            android:text="@string/btn_report"
            android:textAllCaps="false"
            android:textColor="@color/aegis_text"
            android:textSize="12sp" />

        <Button
            android:id="@+id/logsButton"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:minWidth="0dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="@drawable/bg_header_chip"
            android:stateListAnimator="@null"
            android:text="@string/btn_logs"
            android:textAllCaps="false"
            android:textColor="@color/aegis_text"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Status pill: dot + text, pill-shaped chip -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_status_pill"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="14dp"
        android:paddingTop="7dp"
        android:paddingBottom="7dp">

        <View
            android:id="@+id/statusDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/status_dot_idle" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_disconnected"
            android:textColor="@color/aegis_text_dim"
            android:textSize="12sp"
            android:letterSpacing="0.02" />
    </LinearLayout>

    <!-- Video card with detection overlay.
         No background on the FrameLayout — a drawable here would be
         composited in the window layer and paint OVER the SurfaceView's
         compositor surface, turning the stream invisible. The bezel
         View below sits at z=0, the SurfaceViewRenderer renders as a
         media overlay above it, and the detection overlay sits above
         both in the view hierarchy. -->
    <FrameLayout
        android:id="@+id/videoCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="18dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/aegis_surface" />

        <org.webrtc.SurfaceViewRenderer
            android:id="@+id/previewRenderer"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <com.aegisvision.medbud.ui.DetectionOverlayView
            android:id="@+id/detectionOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <!-- Controls -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:weightSum="3">

        <Button
            android:id="@+id/connectButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="54dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/btn_secondary"
            android:stateListAnimator="@null"
            android:text="@string/btn_connect"
            android:textAllCaps="false"
            android:textColor="@color/aegis_text"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/streamButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="54dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/btn_primary"
            android:enabled="false"
            android:stateListAnimator="@null"
            android:text="@string/btn_start_stream"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/askAiButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="54dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/btn_secondary"
            android:stateListAnimator="@null"
            android:text="@string/btn_ask_ai"
            android:textAllCaps="false"
            android:textColor="@color/aegis_text"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
