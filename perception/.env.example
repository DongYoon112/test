# Perception service reads these, falling back to the project-root .env if
# unset. EXPO_PUBLIC_* variants are also accepted to match the existing .env.

OPENAI_API_KEY=sk-...
OPENAI_VISION_MODEL=gpt-4o-mini

ELEVENLABS_API_KEY=sk_...
ELEVENLABS_STT_MODEL_ID=scribe_v1

# Pipeline tuning
PERCEPTION_BUFFER_SIZE=6
PERCEPTION_MIN_INTERVAL_MS=800
PERCEPTION_SPEECH_WINDOW_S=30
